				plugins: [
			  [
			    &#39;component&#39;,
			    {
			      libraryName: &#39;element-ui&#39;,
			      styleLibraryName: &#39;theme-chalk&#39;
			    },
				 ...prodPlugins,
				&#39;@babel/plugin-syntax-dynamic-import&#39;
			  ]
			]
			&lt;/pre&gt;应该这样配置&lt;pre&gt;
		    plugins: [
			  [
			    &#39;component&#39;,
			    {
			      libraryName: &#39;element-ui&#39;,
			      styleLibraryName: &#39;theme-chalk&#39;
			    }
			  ],
				 ...prodPlugins,
				&#39;@babel/plugin-syntax-dynamic-import&#39;
			]
			&lt;/pre&gt;
    
